<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="my-persistence-unit">
        <!-- Указываем ваш класс-сущность -->
        <class>com.MWS.model.User</class>

        <properties>
            <!-- Настройки подключения к БД -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/cloud3_data"/>
            <property name="jakarta.persistence.jdbc.user" value="developer"/>
            <property name="jakarta.persistence.jdbc.password" value="dev123"/>

            <!-- Настройки Hibernate -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.show_sql" value="true"/> <!-- Показывать SQL-запросы в консоли -->
            <property name="hibernate.hbm2ddl.auto" value="update"/> <!-- Автоматически обновлять схему БД -->
        </properties>

    </persistence-unit>
</persistence>
