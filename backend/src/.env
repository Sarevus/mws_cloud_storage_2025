# ==================== Ceph/S3 Configuration ====================
RGW_ACCESS_KEY=MY_CUSTOM_ACCESS_KEY
RGW_SECRET_KEY=MY_CUSTOM_SECRET_KEY

CEPH_ENDPOINT=http://localhost:9000
CEPH_ACCESS_KEY=MY_CUSTOM_ACCESS_KEY
CEPH_SECRET_KEY=MY_CUSTOM_SECRET_KEY
CEPH_BUCKET_NAME=cloudstorage

# ==================== Database Configuration ====================
DB_URL=jdbc:postgresql://localhost:5432/cloud3_data
DB_USER=developer
DB_PASSWORD=dev123
DB_DRIVER=org.postgresql.Driver

# ==================== Server Configuration ====================
SERVER_PORT=12345
MAX_FILE_SIZE_MB=100

# Разрешенные типы файлов (через запятую)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,application/zip

# ==================== Application Configuration ====================
APP_NAME=Cloud Storage Service
APP_VERSION=1.0.0
DEBUG_MODE=false
