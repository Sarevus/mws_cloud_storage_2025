# .env
RGW_ACCESS_KEY=MY_CUSTOM_ACCESS_KEY
RGW_SECRET_KEY=MY_CUSTOM_SECRET_KEY

CEPH_ENDPOINT=http://localhost:9000
CEPH_ACCESS_KEY=MY_CUSTOM_ACCESS_KEY
CEPH_SECRET_KEY=MY_CUSTOM_SECRET_KEY
CEPH_BUCKET_NAME=cloudstorage

# --- required for ceph demo/cluster bootstrap ---
MON_IP=172.20.0.10
CEPH_PUBLIC_NETWORK=172.25.0.0/16

# часто используется в compose
RGW_NAME=rgw
RGW_FRONTEND_PORT=7480
HOST_PORT=7480
CONTAINER_NAME=ceph-rgw

# если в compose есть эти переменные (по твоим прошлым warning-ам)
CEPH_DEMO_UID=demo
CEPH_DEMO_ACCESS_KEY=MY_CUSTOM_ACCESS_KEY
CEPH_DEMO_SECRET_KEY=MY_CUSTOM_SECRET_KEY
CEPH_DEMO_BUCKET=cloudstorage
