# IP-адрес хоста, на котором запускается compose-стек.
# Для Linux можно указать адрес интерфейса `docker0` или фактический IP машины.
CEPH_MON_IP=192.168.1.10

# Публичная сеть кластера Ceph (CIDR). Должна включать CEPH_MON_IP.
CEPH_PUBLIC_NETWORK=192.168.1.0/24

# TCP-порт, на котором RGW будет принимать запросы. 7480 — порт по умолчанию.
CEPH_RGW_PORT=7480

# Имя S3-совместимого пользователя, который будет создан для backend-а.
CEPH_RGW_USER=mws-backend

# Имя бакета по умолчанию.
CEPH_RGW_BUCKET=mws-user-files

# Realm и zone для RGW (используются в скрипте создания пользователя).
CEPH_RGW_REALM=default
CEPH_RGW_ZONEGROUP=default
CEPH_RGW_ZONE=default
