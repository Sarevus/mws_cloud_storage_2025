# Endpoint Ceph RGW (в формате URL). Используйте IP и порт из compose-стека.
CEPH_ENDPOINT=http://192.168.1.10:7480

# Ключи доступа, возвращённые `radosgw-admin user create`.
CEPH_ACCESS_KEY=REPLACE_WITH_ACCESS_KEY
CEPH_SECRET_KEY=REPLACE_WITH_SECRET_KEY

# Имя бакета, куда будут складываться пользовательские файлы.
CEPH_BUCKET=mws-user-files

# Регион используется AWS SDK. Для Ceph можно указать произвольное значение.
CEPH_REGION=us-east-1

# Необязательно: включить path-style адресацию (нужно для Ceph RGW).
CEPH_FORCE_PATH_STYLE=true
